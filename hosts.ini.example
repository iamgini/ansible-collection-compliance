# Example Inventory for SCAP Compliance Scanning
# Copy this file to hosts.ini and customize with your environment details
#
# Usage: cp hosts.ini.example hosts.ini
# Then edit hosts.ini with your actual hostnames, IPs, and credentials

# RHEL9 hosts - CIS Level 2 Server Profile
[rhel9_cis_l2]
rhel9-server-01 ansible_host=192.168.1.101 ansible_user=ansible
rhel9-server-02 ansible_host=192.168.1.102 ansible_user=ansible
# ansible_ssh_private_key_file=~/.ssh/id_rsa
# ansible_become_pass=vault_encrypted_password

# Profile configuration is set in group_vars/rhel9_cis_l2.yml (optional)
[rhel9_cis_l2:vars]
# Add group-level overrides here if needed
# customer_id=production-servers

# RHEL9 hosts - CIS Level 1 Server Profile
[rhel9_cis_l1]
rhel9-web-01 ansible_host=192.168.1.201 ansible_user=ansible
rhel9-web-02 ansible_host=192.168.1.202 ansible_user=ansible

[rhel9_cis_l1:vars]
# Uses group_vars/rhel9_cis_l1.yml if present
# cis_profile=xccdf_org.ssgproject.content_profile_cis_level1_server

# RHEL9 hosts - DISA STIG Profile
[rhel9_stig]
rhel9-secure-01 ansible_host=192.168.1.151 ansible_user=ansible

[rhel9_stig:vars]
# Uses group_vars/rhel9_stig.yml if present
# cis_profile=xccdf_org.ssgproject.content_profile_stig

# Report Server - hosts the compliance reports
[report_server]
report-server ansible_host=192.168.1.10 ansible_user=ansible
# ansible_ssh_private_key_file=~/.ssh/id_rsa

# Example: Testing with localhost
# Uncomment to test scanning localhost
# [localhost_test]
# localhost ansible_connection=local

# Example: Using SSH jump host
# [production_servers]
# prod-01 ansible_host=10.0.1.100 ansible_user=ansible ansible_ssh_common_args='-o ProxyJump=jumphost.example.com'
